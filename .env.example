# MT5 Trading Bot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# MetaTrader 5 Connection (Primary Account)
# ============================================
# Note: Additional accounts can be added via the UI
# with encrypted storage (no .env needed)
MT5_LOGIN=0
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo
MT5_PATH=

# ============================================
# Account Encryption
# ============================================
# Encryption key for storing MT5 credentials securely
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a key will be auto-generated on first run
ENCRYPTION_KEY=

# ============================================
# Telegram Alerts
# ============================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================
# Discord Alerts
# ============================================
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ============================================
# Risk Management
# ============================================
MAX_RISK_PER_TRADE=2.0
MAX_DAILY_LOSS=5.0
MAX_DRAWDOWN=20.0
MAX_POSITIONS=5
MAX_POSITIONS_PER_SYMBOL=2

# Circuit Breaker Settings
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_CONSECUTIVE_LOSSES=3
CIRCUIT_BREAKER_COOLDOWN_MINUTES=60

# Correlation Risk
MAX_CORRELATED_EXPOSURE=3.0

# ============================================
# Trading Settings
# ============================================
DEFAULT_LOT_SIZE=0.01
DEFAULT_MAGIC_NUMBER=123456
SLIPPAGE=10
CHECK_INTERVAL=1

# Trailing Stop Settings
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PIPS=30
TRAILING_STOP_DISTANCE_PIPS=20

# Break-Even Settings
BREAKEVEN_ENABLED=true
BREAKEVEN_TRIGGER_PIPS=20
BREAKEVEN_OFFSET_PIPS=2

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# ============================================
# UI Settings
# ============================================
UI_REFRESH_RATE=5
UI_THEME=dark
